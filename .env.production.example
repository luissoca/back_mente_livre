# -----------------------------------------------------------------------
# SMTP — Correos transaccionales (PHPMailer)
# Dejar en blanco para deshabilitar emails (el sistema sigue funcionando)
# -----------------------------------------------------------------------

# Servidor SMTP
# Ejemplos:
#   Gmail:       smtp.gmail.com  (usar App Password, no la contrasena normal)
#   Hostinger:   smtp.hostinger.com
#   Brevo:       smtp-relay.brevo.com
#   Mailgun:     smtp.mailgun.org
MAIL_HOST=smtp.hostinger.com

# Puerto SMTP
# 587 = STARTTLS (recomendado)
# 465 = SSL/SMTPS
# 25  = sin cifrado (no recomendado)
MAIL_PORT=587

# Credenciales SMTP
MAIL_USERNAME=no-reply@mentelivre.com
MAIL_PASSWORD=tu_password_smtp_aqui

# Remitente que verá el destinatario
MAIL_FROM_ADDRESS=no-reply@mentelivre.com
MAIL_FROM_NAME=Mente Livre

# Email del administrador (recibe alertas internas)
ADMIN_EMAIL=admin@mentelivre.com

# -----------------------------------------------------------------------
# URLs
# -----------------------------------------------------------------------

# URL del frontend (se usa en los links de los emails)
# Sin barra al final
FRONTEND_URL=https://mentelivre.com
